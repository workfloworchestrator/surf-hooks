      "hooks": [
        { "type": "command", "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/python_style_hook.py" },
        { "type": "command", "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/test_param_hook.py" }
      ]
    }
  ],
  "UserPromptSubmit": [
    {
      "hooks": [
        { "type": "command", "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/python_style_primer.py" }
      ]
    }
  ]
}
